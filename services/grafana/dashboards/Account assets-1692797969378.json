          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH current_prices AS (\n  SELECT \n    exchange, account_type, instrument, (bid + ask)/2 as price\n  FROM price_tickers\n  WHERE exchange = 'BINANCE' and account_type = 'LINEAR_FUTURES'\n  LATEST ON timestamp PARTITION BY instrument\n)\nSELECT pos.instrument, account_name, pos.account_type, position_side, amount, price_entry, price, unrealized_profit\nFROM positions pos\nINNER JOIN current_prices ON (instrument)\nWHERE pos.exchange = 'BINANCE' and pos.account_type = 'LINEAR_FUTURES' and pos.account_name = '$account_name'\nLATEST ON timestamp PARTITION BY instrument;",
