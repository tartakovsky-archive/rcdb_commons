          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH hourly_snapshots AS (\n  SELECT \n    timestamp, account_name, asset, LAST(total_usd) as total_usd\n  FROM spot_balances\n  WHERE timestamp >= DATEADD('d', -1, DATE_TRUNC('hour', NOW())) AND timestamp < DATE_TRUNC('hour', NOW())  -- get bigger range to ensure that it has all assets\n  SAMPLE BY 1m FILL(PREV)\n  ALIGN TO CALENDAR TIME ZONE 'UTC'\n  GROUP BY timestamp, account_name, asset\n)\nSELECT \n  hourly_snapshots.timestamp, SUM(hourly_snapshots.total_usd) as spot_balance\nFROM hourly_snapshots\nGROUP BY timestamp",
