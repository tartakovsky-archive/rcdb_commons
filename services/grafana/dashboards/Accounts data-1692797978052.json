      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH sampled_asset_balance AS (\n  SELECT\n    account_name,\n    asset,\n    LAST(total_usd) as total_usd,\n    timestamp as latest_update\n  FROM spot_balances\n  WHERE timestamp >= DATEADD('m', -5, DATE_TRUNC('minute', NOW())) AND timestamp < DATE_TRUNC('minute', NOW())\n  SAMPLE BY 30s FILL(PREV)\n  GROUP BY timestamp, account_name, asset\n)\n,\nsampled_spot_balance AS (SELECT\n    account_name,\n    SUM(total_usd) as total_usd,\n    latest_update\n  FROM sampled_asset_balance\n  GROUP BY account_name, latest_update\n  \n  UNION\n  \n  SELECT\n    account_name,\n    SUM(total_usd) as total_usd,\n    MAX(timestamp) as latest_update\n  FROM spot_balances\n  WHERE account_name NOT IN (SELECT account_name FROM sampled_asset_balance)\n  LATEST ON timestamp PARTITION BY account_name, asset\n  GROUP BY account_name\n)\n,\nbalance AS (Select \n    account_name, \n    MAX(total_usd) as total_usd,\n    MAX(latest_update) as latest_update\n  from sampled_spot_balance\n  GROUP BY account_name\n),\nvolumes_week AS (\n    SELECT\n     account_name,\n     SUM(volume_usd) as volume_usd,\n     MAX(timestamp) as latest_update\n  FROM et_trades\n  WHERE account_type = 'spot' AND timestamp >= DATE_TRUNC('week', now()) AND timestamp < now()\n  GROUP BY account_name\n),\nvolumes_24h AS (\n    SELECT\n     account_name,\n     SUM(volume_usd) as volume_usd\n  FROM et_trades\n  WHERE account_type = 'spot' AND timestamp >= dateadd('h', -24, now()) AND timestamp < now()\n  GROUP BY account_name\n),\nvolumes_1h AS (\n    SELECT\n     account_name,\n     SUM(volume_usd) as volume_usd\n  FROM et_trades\n  WHERE account_type = 'spot' AND timestamp >= dateadd('h', -1, now()) AND timestamp < now()\n  GROUP BY account_name\n)\nSELECT\n    balance.account_name,\n    SUM(balance.total_usd) as total_usd,\n    volumes_1h.volume_usd as volume_1h,\n    volumes_24h.volume_usd as volume_24h,\n    volumes_week.volume_usd as volume_week,\n    balance.latest_update as latest_balance_update,\n    volumes_week.latest_update as latest_volume_update\nFROM balance\nLEFT JOIN volumes_week ON balance.account_name = volumes_week.account_name\nLEFT JOIN volumes_24h ON balance.account_name = volumes_24h.account_name\nLEFT JOIN volumes_1h ON balance.account_name = volumes_1h.account_name\nORDER BY account_name;",
          "refId": "A",
