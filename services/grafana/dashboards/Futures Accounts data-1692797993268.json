      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH futures_balance AS (\n  SELECT\n    account_name,\n    SUM(total_usd) as total_usd,\n    MAX(timestamp) as latest_update\n  FROM futures_balances\n  WHERE account_type = 'LINEAR_FUTURES'\n  LATEST ON timestamp PARTITION BY account_name, asset\n  GROUP BY account_name\n),\nactual_positions AS (\n  SELECT instrument, account_type, account_name, position_side, amount, price_entry, price_row, unrealized_profit, timestamp\n  FROM positions\n  LATEST ON timestamp PARTITION BY account_name, instrument\n),\nlast_prices AS (\n  SELECT account_type, instrument, (bid + ask)/2 as price, timestamp\n  FROM price_tickers\n  WHERE account_type = 'LINEAR_FUTURES' and timestamp > dateadd('h', -1, now())\n  LATEST ON timestamp PARTITION BY instrument \n),\npnl AS (\n  SELECT sp.account_name, SUM(sp.unrealized_profit / sp.price_row * lp.price) as unrealized_profit_current\n  FROM actual_positions sp \n  LEFT JOIN last_prices lp on sp.instrument = lp.instrument \n  WHERE sp.amount <> 0\n  GROUP BY sp.account_name\n)\nSELECT\n    futures_balance.account_name,\n    SUM(futures_balance.total_usd) as balance,\n    SUM(pnl.unrealized_profit_current) as pnl, \n    MAX(futures_balance.latest_update) as latest_balance_update\nFROM futures_balance \nLEFT JOIN pnl ON futures_balance.account_name = pnl.account_name \nGROUP BY futures_balance.account_name\nORDER BY futures_balance.account_name;\n;",
          "refId": "A",
          "sql": {
            "columns": [
